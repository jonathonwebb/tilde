{
	"name": "tilde",
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"build": "node ./bin/build",
		"start": "node --enable-source-maps ./bin/tilde",
		"lint": "biome ci .",
		"lint:fix": "biome check --write .",
		"types": "tsc -p tsconfig.json --noEmit",
		"check": "pnpm run lint && pnpm run types",
		"clean": "rm -rf out"
	},
	"license": "MIT",
	"dependencies": {
		"@fastify/static": "^8.1.1",
		"fastify": "^5.2.1",
		"fastify-plugin": "^5.0.1",
		"pino": "^9.6.0",
		"pino-pretty": "^13.0.0",
		"ws": "^8.18.1"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@types/node": "^22.13.10",
		"esbuild": "^0.25.1",
		"typescript": "^5.8.2"
	},
	"engines": {
		"node": ">=22.14.0"
	},
	"packageManager": "pnpm@10.6.5",
	"pnpm": {
		"onlyBuiltDependencies": ["@biomejs/biome", "esbuild"]
	}
}
