{
	"$schema": "https://swc.rs/schema.json",
	"jsc": {
		"target": "es2022",
		"parser": {
			"syntax": "typescript",
			"decorators": true
		},
		"transform": {
			"legacyDecorator": true,
			"decoratorMetadata": true
		},
		"experimental": {
			"keepImportAttributes": true
		},
		"preserveAllComments": true
	},
	"sourceMaps": "inline"
}
